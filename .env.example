# Application
APP_ENV=development
APP_NAME=digital-personality
APP_LOG_LEVEL=debug

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=digital_personality
POSTGRES_USER=dp_user
POSTGRES_PASSWORD=dp_secret
POSTGRES_MAX_CONNS=25
POSTGRES_MIN_CONNS=5
POSTGRES_MAX_CONN_LIFETIME=1h
POSTGRES_MAX_CONN_IDLE_TIME=30m

# Telegram MTProto
TELEGRAM_APP_ID=
TELEGRAM_APP_HASH=
TELEGRAM_SESSION_FILE=/data/sessions/telegram.session
TELEGRAM_PHONE=+1234567890         # your phone number in international format
TELEGRAM_2FA_PASSWORD=             # optional: 2FA cloud password; leave empty if not set

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BATCH_SIZE=100

# Embedding pipeline
EMBEDDING_WORKER_COUNT=4
EMBEDDING_QUEUE_SIZE=1000
EMBEDDING_RETRY_MAX=3
EMBEDDING_RETRY_DELAY=5s
